{
  "name": "quicktab",
  "version": "0.1.4",
  "description": "QuickTab desktop app for searching and switching browser tabs, bookmarks, and history.",
  "type": "module",
  "main": "dist/src/main/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:electron": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -p tsconfig.json && node scripts/sync-preload.mjs && vite build",
    "start": "electron .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "extension:id": "node scripts/extension-id.mjs",
    "extension:prepare": "node scripts/extension-id.mjs --json",
    "smoke:native-host": "node scripts/smoke-native-host.mjs",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "register:native-host": "node scripts/register-native-host.mjs",
    "unregister:native-host": "node scripts/unregister-native-host.mjs",
    "uninstall:mac": "bash scripts/uninstall-macos.sh",
    "native-host": "node dist/src/main/native/native-host.js"
  },
  "keywords": [
    "electron",
    "browser-extension",
    "native-messaging",
    "search"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.13",
    "wait-on": "^9.0.1"
  },
  "dependencies": {
    "lucide-react": "^0.475.0",
    "pinyin-pro": "^3.28.1",
    "plist": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.quicktab.ai",
    "productName": "QuickTab",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "extension/chromium",
        "to": "extension/chromium"
      },
      {
        "from": "docs/IMPLEMENTATION.md",
        "to": "docs/IMPLEMENTATION.md"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
