{
  "manifest_version": 3,
  "name": "QuickTab Connector",
  "version": "0.1.0",
  "description": "Syncs tabs, bookmarks, and history with the local QuickTab desktop app.",
  "permissions": [
    "tabs",
    "bookmarks",
    "history",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "QuickTab"
  },
  "key": ""
}
